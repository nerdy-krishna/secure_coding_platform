# =============================================================================
# SECURITY NOTICE (ASVS V13.3.1)
# =============================================================================
# All lines marked REPLACE_ME MUST be replaced with real values before any
# non-laptop deployment. The application refuses to start if it detects
# placeholder values (see app.config.config Settings validator).
#
# For production deployments, source these values from a secrets manager
# (HashiCorp Vault, AWS Secrets Manager, or a SOPS-encrypted file) rather
# than a hand-edited .env file — per ASVS V13.3.1.
#
# Variables marked [LONG-LIVED CREDENTIAL] should be rotated per your
# organisation's secret-rotation policy before any deployment.
# =============================================================================

# CLASSIFICATION: internal (database user)
POSTGRES_USER=postgres
# CLASSIFICATION: secret (DB credential) [LONG-LIVED CREDENTIAL — rotate before deploy]
# Replace with a strong random password, e.g.: openssl rand -hex 32
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=secure_coding_platform
# CLASSIFICATION: internal (message broker user) [LONG-LIVED CREDENTIAL — rotate before deploy]
RABBITMQ_DEFAULT_USER=user
# CLASSIFICATION: secret (message broker credential) [LONG-LIVED CREDENTIAL — rotate before deploy]
# Replace with a strong random password, e.g.: openssl rand -hex 32
RABBITMQ_DEFAULT_PASS=REPLACE_ME
# CLASSIFICATION: secret (JWT signing key)
# Replace with a strong random value, e.g.: openssl rand -hex 32
SECRET_KEY=REPLACE_ME
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173
# Note: LLM provider API keys (OpenAI, Anthropic, Google) are NOT stored
# as env vars. Admins enter them per-model at Setup or under Admin → LLM
# Configurations; they're Fernet-encrypted in the llm_configurations
# table using ENCRYPTION_KEY below.
# Added variables based on log errors
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_HOST_ALEMBIC=db
RABBITMQ_HOST=rabbitmq
# CLASSIFICATION: secret (encryption key, do not log)
# REQUIRED. Generate a real Fernet key before any deployment:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# OR: python scripts/generate_secrets.py fernet
# The application refuses to start if this placeholder is not replaced.
ENCRYPTION_KEY=REPLACE_ME_GENERATE_VIA_python_scripts_generate_secrets_py_fernet

# Email Settings (Optional but required for sending user setup emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
# CLASSIFICATION: secret (SMTP credential)
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@example.com

# --- RAG vector store (Qdrant) ---------------------------------------
# NOTE (ASVS V12.3.3): For non-laptop deployments, front Qdrant with TLS
# (sidecar reverse proxy or service mesh) and set QDRANT_USE_HTTPS=true
# with QDRANT_PORT=6334. Plain HTTP is dev-only.
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# Uncomment and set for TLS (ASVS L2 requirement for non-laptop deploys):
# QDRANT_USE_HTTPS=true
# QDRANT_PORT=6334
# CLASSIFICATION: secret (vector store API key)
# REQUIRED. The application refuses to start with this placeholder
# value (the validator in app.config.config rejects it). Generate a
# real one via e.g. `openssl rand -hex 32` and put it here.
QDRANT_API_KEY=change-me-qdrant-key

# --- Observability (Langfuse v3, optional) ----------------------------
# All values below are placeholders. Generate real keys after first
# `docker compose up langfuse-web` by signing in at $VITE_LANGFUSE_HOST
# and creating a Project. Disabled until LANGFUSE_ENABLED=true.
LANGFUSE_ENABLED=false
# NOTE (ASVS V12.3.1 / V12.3.3): http://langfuse-web:3000 is dev-only.
# For any non-laptop deploy, set LANGFUSE_HOST to an HTTPS endpoint behind
# a reverse proxy, e.g.: LANGFUSE_HOST=https://langfuse.<your-domain>
# Supply CA bundle for self-signed internal CAs via REQUESTS_CA_BUNDLE or
# SSL_CERT_FILE. Plain HTTP must NOT be used in production.
LANGFUSE_HOST=http://langfuse-web:3000
# CLASSIFICATION: internal (Langfuse public key)
LANGFUSE_PUBLIC_KEY=change-me-langfuse-public
# CLASSIFICATION: secret (LLM observability)
LANGFUSE_SECRET_KEY=change-me-langfuse-secret
# UI link in the SCCAP admin panel (read by Vite at build time).
VITE_LANGFUSE_HOST=http://localhost:3001
# Self-hosting: backing-service credentials. Replace ALL of these before
# bringing the stack up in any non-laptop deploy.
# CLASSIFICATION: secret (Langfuse DB credential) [LONG-LIVED CREDENTIAL — rotate before deploy]
# Replace with a strong random password, e.g.: openssl rand -hex 32
LANGFUSE_POSTGRES_PASSWORD=REPLACE_ME
# CLASSIFICATION: secret (ClickHouse credential) [LONG-LIVED CREDENTIAL — rotate before deploy]
# Replace with a strong random password, e.g.: openssl rand -hex 32
CLICKHOUSE_PASSWORD=REPLACE_ME
# CLASSIFICATION: secret (Redis credential) [LONG-LIVED CREDENTIAL — rotate before deploy]
# Replace with a strong random password, e.g.: openssl rand -hex 32
REDIS_PASSWORD=REPLACE_ME
MINIO_ROOT_USER=langfuse
# CLASSIFICATION: secret (MinIO credential) [LONG-LIVED CREDENTIAL — rotate before deploy]
# Replace with a strong random password, e.g.: openssl rand -hex 32
MINIO_ROOT_PASSWORD=REPLACE_ME
# CLASSIFICATION: secret (encryption key, do not log)
# 64 hex characters required. Generate via: openssl rand -hex 32
# The application refuses to start if this placeholder is not replaced.
LANGFUSE_ENCRYPTION_KEY=REPLACE_ME_64_HEX_CHARS_RUN_openssl_rand_-hex_32
# CLASSIFICATION: secret (Langfuse salt)
LANGFUSE_SALT=REPLACE_ME
# CLASSIFICATION: secret (NextAuth signing secret)
# Replace with a strong random value, e.g.: openssl rand -hex 32
NEXTAUTH_SECRET=REPLACE_ME
# Cap session lifetime so an offboarded SCCAP user can't read traces
# indefinitely (threat model #5). Default 24h.
NEXTAUTH_SESSION_MAXAGE=86400
# Auto-create the first admin on container init. Subsequent users are
# invited from the Langfuse UI.
LANGFUSE_INIT_USER_EMAIL=admin@example.local
# CLASSIFICATION: secret (Langfuse admin password) [LONG-LIVED CREDENTIAL — rotate before deploy]
# Replace with a strong random password, e.g.: openssl rand -hex 16
LANGFUSE_INIT_USER_PASSWORD=REPLACE_ME
# ClickHouse retention. Caps disk growth (threat model #7).
LANGFUSE_TRACE_RETENTION_DAYS=30
# Web UI host port (avoid 3000 — Grafana already owns it).
LANGFUSE_WEB_PORT=3001

# --- Log retention (ADR-010) ----------------------------------------
# Loki retention period. Accepts Loki duration strings: 30d, 4w, 720h.
# Compliance: PCI-DSS 10.5.3 / HIPAA 164.312(b) typically require
# >= 1 year audit-log retention. Operators bound by those regimes
# must set LOKI_RETENTION_DAYS=365d AND provision a larger volume
# for `loki-data` (or ship logs to long-term cold storage before
# upgrade — the compactor deletes >LOKI_RETENTION_DAYS data on its
# first cycle, irreversibly).
LOKI_RETENTION_DAYS=30d
