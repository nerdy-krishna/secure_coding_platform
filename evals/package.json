{
  "name": "sccap-evals",
  "version": "0.1.0",
  "private": true,
  "description": "Promptfoo eval harness for SCCAP agents. Mock-by-default; live opt-in via the evals.yml workflow_dispatch button.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "promptfoo eval -c agents/generic_specialized/promptfooconfig.yaml --no-progress-bar && promptfoo eval -c agents/chat/promptfooconfig.yaml --no-progress-bar",
    "test:gs": "promptfoo eval -c agents/generic_specialized/promptfooconfig.yaml --no-progress-bar",
    "test:chat": "promptfoo eval -c agents/chat/promptfooconfig.yaml --no-progress-bar"
  },
  "dependencies": {
    "promptfoo": "~0.121.0"
  }
}
