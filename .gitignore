# Fluentd / Logging Artifacts
# Ignore logs, buffer files, and position tracking files generated by Fluentd.
fluentd/log/
fluentd/buffer/
*.pos
# .agent/ is load-bearing operational docs — track its markdown.
# The bulky recovery files (.agent/backend.txt, .agent/frontend.txt) are
# already excluded by the global *.txt rule below.
*.txt
*.patch
cookies.txt
debug_*.py
check_chroma_count.py
trigger_chat.py

# Claude Code / SCCAP harness — local tooling, not part of the app.
# .claude/ holds per-session state, agent definitions, and worktrees;
# .agent/ holds operational notes, runbooks, and per-run work products
# from the SCCAP harness. None of this is needed to build or run SCCAP.
.claude/
.agent/

# Diagram + log output from the swark generator — generated artefacts.
swark-output/

# Promptfoo eval scratch dirs (committed: package-lock.json, source files,
# extracted prompt .txt files — see negation rules below).
evals/node_modules/
evals/results/
evals/.cache/
evals/.promptfoo/

# Whitelist the extracted prompt files even though `*.txt` is globally
# ignored above (line ~174). These are committed and CI checks them.
!evals/agents/**/prompts/*.txt
